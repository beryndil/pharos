<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Minimal permission set (security: least privilege). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Alarm engine (Slice 4, spec §3.4, Standards §3). -->
    <!-- USE_EXACT_ALARM: auto-granted for a dedicated reminder app; primary exact-alarm grant. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- SCHEDULE_EXACT_ALARM: revocable fallback path; gated by canScheduleExactAlarms(). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- Full-screen DUE alert that takes over the screen (Android 14 restricts to alarm apps). -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <!-- Runtime notification permission on API 33+ (dose channel). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Re-register alarms after device boot (Standards §2, §10). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Lets the onboarding flow open the per-app battery-optimization settings page
         (ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS). Normal permission — auto-granted. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:name=".PharosApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/backup_rules"
        android:fullBackupContent="@xml/backup_rules_legacy"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locale_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pharos">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Pharos">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Full-screen dose-due alert. Not exported: launched only by our own full-screen
             intent. showWhenLocked/turnScreenOn are set in code; singleTask + excludeFromRecents
             keep one alert instance and out of the recents list. -->
        <activity
            android:name=".alarm.DueAlertActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleTask"
            android:showOnLockScreen="true"
            android:taskAffinity=""
            android:theme="@style/Theme.Pharos" />

        <!-- Receives our own fired alarms (dose-due, test, daily rollover, dose-state timed
             transitions). Not exported: only AlarmManager-delivered PendingIntents target it. -->
        <receiver
            android:name=".alarm.AlarmReceiver"
            android:exported="false" />

        <!-- Receives Take/Snooze/Skip taps from the dose notification (Slice 5). Not exported:
             only our own notification-action PendingIntents target it. -->
        <receiver
            android:name=".alarm.DoseActionReceiver"
            android:exported="false" />

        <!-- Rebuilds the pending alarm after protected system broadcasts (Standards §2, §3.4).
             exported=true is safe: these are protected broadcasts only the OS can send. -->
        <receiver
            android:name=".alarm.AlarmReRegistrationReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.app.action.SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
