    <!-- Privacy policy — describes local storage, CDN fetch, openFDA fetch, opt-in crash. -->
    <string name="legal_section_privacy_policy">Privacy policy</string>
    <string name="legal_privacy_intro">Pharos stores all your medication and health data locally on this device. No account is required. No personal data is sent to Beryndil or any third party as part of normal operation.</string>
    <string name="legal_privacy_data_out_heading">What leaves your device</string>
    <string name="legal_privacy_cdn">Drug database updates: Pharos periodically checks a content delivery network operated by Beryndil for updates to the drug reference database. This check transmits no personal data — only a version number is compared.</string>
    <string name="legal_privacy_openfda">Drug label data: When you add a medication resolved from the drug database, Pharos may fetch its label text from the openFDA public API (U.S. Food and Drug Administration). This request includes the drug\'s RxCUI identifier — no personal information. Fetched data is cached locally on your device.</string>
    <string name="legal_privacy_data_in_heading">What stays on your device</string>
    <string name="legal_privacy_local_storage">Your medication list, schedule, dose history, refill records, and backup files are stored locally and encrypted at rest. They are not transmitted to any server.</string>
    <string name="legal_privacy_no_cloud_backup">Android device backup (Google Backup) is disabled for all health data. Your medication data is not backed up to Google\'s servers.</string>
    <string name="legal_privacy_crash_reporting">Crash reporting is off by default. If opt-in crash reporting is added in a future version, it will require your explicit consent and will be described in an update to this policy.</string>
    <string name="legal_privacy_version_note">This policy applies to Pharos version 1.0.0.</string>

